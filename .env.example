# =============================================================
# Tecno Caja - Plantilla de configuración
# Copia este archivo a .env y llena los valores reales.
# NUNCA commits .env al repositorio.
# =============================================================

# --- Servidor ---
# Puerto HTTP local. Electron usa 3399 por defecto; standalone usa 3000.
PORT=3000

# Host de binding. Mantén 127.0.0.1 (seguro).
# Con Cloudflare Tunnel NO necesitas cambiar esto — el túnel se conecta a localhost.
# Cambia a 0.0.0.0 SOLO si usas LAN sin túnel y sabes lo que haces.
POS_BIND_HOST=127.0.0.1

# Permitir conexiones desde la LAN (para caja secundaria en la misma red). true/false.
# Con Cloudflare Tunnel NO necesitas activar esto.
POS_ALLOW_LAN=false

# Orígenes CORS adicionales permitidos, separados por coma.
# Solo relevante si usas la app de reportes como Flutter WEB (no mobile).
# Mobile Android/iOS no necesita esto (no envía Origin header).
# Ejemplo con Cloudflare Tunnel: https://mitienda.cfargotunnel.com
CORS_ALLOWED_ORIGINS=

# --- Base de datos ---
# Cliente a usar: mysql (MariaDB/MySQL) o sqlite
DB_CLIENT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tecnocaja
# Si la PC principal alojará la base para otras cajas en la LAN:
TECNO_CAJA_MYSQL_ALLOW_LAN=false
TECNO_CAJA_MYSQL_BIND_HOST=127.0.0.1
# Credenciales dedicadas para terminales remotas.
# Si se dejan vacías, Tecno Caja puede generarlas al preparar la red.
TECNO_CAJA_LAN_DB_USER=
TECNO_CAJA_LAN_DB_PASSWORD=
DB_FILE=
SQLITE_SOURCE_FILE=

# --- Seguridad ---
# Contraseña maestra de respaldos/seguridad. Si se deja vacía, el sistema
# genera una aleatoria en el primer arranque y la guarda en userData.
# ¡NO USES 'Seguridad2026' en producción!
TECNO_CAJA_SECURITY_PASSWORD=

# Clave de activación de licencia admin
ADMIN_LICENSE_KEY=

# UID de licencia del POS (obtener desde el panel de admin)
TECNO_CAJA_LICENSE_UID=

# Verificación de licencias:
# - En producción, idealmente usa firma asimétrica (ed25519) y coloca SOLO la llave pública aquí.
# - Si temporalmente usas HMAC, define TECNO_CAJA_LICENSE_HMAC_SECRET fuera del repositorio.
TECNO_CAJA_LICENSE_PUBLIC_KEY=
TECNO_CAJA_LICENSE_HMAC_SECRET=
TECNO_CAJA_LICENSE_SIGNATURE_ALG=hmac-sha256
TECNO_CAJA_LICENSE_REQUIRE_SIGNATURE=
TECNO_CAJA_LICENSE_OFFLINE_GRACE_DAYS=3

# Secretos locales de endurecimiento.
# Si se dejan vacíos, Tecno Caja los genera en el primer arranque y los persiste
# dentro del userData de la instalación.
TECNO_CAJA_LICENSE_STORAGE_SECRET=
TECNO_CAJA_DB_KEY_SALT=
TECNO_CAJA_DEVICE_SECRET=

# --- Firebase (opcional, solo si usas sync en la nube) ---
FIREBASE_PROJECT_ID=
# Ruta absoluta al service account JSON. Mantenlo FUERA del repo.
FIREBASE_SERVICE_ACCOUNT_PATH=
# Alternativa: pegar el JSON inline (base64 o texto). Prioriza PATH.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_POS_CLIENTS_COLLECTION=pos_clientes

# --- Integraciones externas ---
# URL pública del POS (tu dominio de Cloudflare Tunnel u otro).
# Configura esto cuando uses Cloudflare Tunnel para acceso remoto.
# Ejemplo: https://mitienda.cfargotunnel.com
# Esta misma URL la pones en la app de reportes → Configuración → Servidor Tecno Caja.
POS_PUBLIC_BASE_URL=

# API key de Pexels (para búsqueda de imágenes de productos)
PEXELS_API_KEY=

# --- Facturación Electrónica DGII (e-CF) ---
# Selector oficial de ambiente: testecf | certecf | ecf
DGII_ENV=testecf

# Overrides directos del módulo nuevo (déjalos vacíos para usar endpoints oficiales automáticos)
DGII_BASE_URL=
DGII_AUTH_URL=
DGII_RECEPCION_URL=
DGII_CONSULTA_URL=
DGII_CONSULTA_ESTADO_URL=
DGII_FC_URL=
DGII_SEMILLA_URL=
DGII_VALIDAR_SEMILLA_URL=
DGII_RNC=
DGII_USER=
DGII_PASSWORD=
CERT_PATH=
CERT_PASSWORD=
TOKEN_DURATION=3600
DEBUG_ECF=true

# Clave para cifrar el certificado .p12 en la base de datos (AES-256-GCM).
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ¡OBLIGATORIO para usar e-CF! Sin esto el módulo no arranca.
FISCAL_CERT_SECRET=

# Clave para cifrar el token DGII en la base de datos (AES-256-GCM).
# Puede ser la misma que FISCAL_CERT_SECRET o una diferente.
FISCAL_TOKEN_SECRET=

# URL pública HTTPS del backend que registrarás ante DGII.
# Ejemplo: https://api.midominio.com
DGII_PUBLIC_BASE_URL=
TECNO_CAJA_ENABLE_SERVEO_TUNNEL=false

# Directorio local donde se archivarán XML/JSON por empresa/año/mes.
DGII_STORAGE_DIR=

# Seguridad de rutas públicas DGII.
# Si lo activas, envía Authorization: Bearer <token> o x-internal-token.
DGII_REQUIRE_INTERNAL_TOKEN=false
DGII_INTERNAL_TOKEN=
# Alternativa segura si ya tienes el hash SHA-256 calculado.
DGII_INTERNAL_TOKEN_HASH=

# Orígenes web permitidos específicamente para estas rutas públicas.
# Déjalo vacío para heredar CORS_ALLOWED_ORIGINS.
DGII_PUBLIC_ALLOWED_ORIGINS=

# URLs opcionales para forward/proxy real de la semilla cuando tengas
# credenciales y endpoint del contribuyente o middleware homologado.
DGII_FORWARD_SEMILLA_URL_TEST=
DGII_FORWARD_SEMILLA_URL_CERTIFICACION=
DGII_FORWARD_SEMILLA_URL_PRODUCCION=

# Overrides opcionales de endpoints oficiales DGII por ambiente.
# Útiles si DGII cambia rutas o si homologas vía gateway propio.
DGII_AUTH_BASE_URL_TEST=
DGII_AUTH_BASE_URL_CERTIFICACION=
DGII_AUTH_BASE_URL_PRODUCCION=
DGII_ECF_BASE_URL_TEST=
DGII_ECF_BASE_URL_CERTIFICACION=
DGII_ECF_BASE_URL_PRODUCCION=
DGII_FC_BASE_URL_TEST=
DGII_FC_BASE_URL_PRODUCCION=

# Archivo mensual de XML firmados.
# Si se deja vacío se usa TECNO_CAJA_USER_DATA/fiscal/xml
FISCAL_XML_DIR=

# Umbral DGII para canal RFCE (Factura de Consumo resumida).
DGII_RFCE_THRESHOLD_DOP=250000

# Solo para pruebas controladas.
# En producción déjalo en false hasta implementar RFCE firmado real.
DGII_ALLOW_E32_FULL_RECEPTION=false
