# ============================================================
#  Tecno Caja — Configuración para PC SECUNDARIA (Terminal Caja)
# ============================================================
#
#  Copia este archivo como ".env" en el PC secundario.
#  Reemplaza los valores marcados con <CAMBIAR> antes de usar.
#
#  PASO RÁPIDO:
#    1. Instala Tecno Caja normalmente en el PC secundario.
#    2. Copia este archivo como ".env" en la carpeta del programa.
#    3. Cambia DB_HOST por la IP local del PC principal.
#    4. Corre: npm run desktop
#
#  Para encontrar la IP del PC principal (Windows):
#    Abre cmd → escribe: ipconfig
#    Busca: "Dirección IPv4" bajo tu adaptador de red (ej. 192.168.1.10)
# ============================================================

# ── Base de datos ────────────────────────────────────────────
# El PC secundario NO arranca su propio MySQL.
# Se conecta al MySQL del PC PRINCIPAL por la red local.
DB_CLIENT=mysql
DB_HOST=<IP_DEL_PC_PRINCIPAL>    # Ejemplo: 192.168.1.10
DB_PORT=3399
DB_USER=tecnocaja_terminal
DB_PASSWORD=<TECNO_CAJA_LAN_DB_PASSWORD_DEL_PC_PRINCIPAL>
DB_NAME=tecnocaja

# ── Puerto local del servidor Express ───────────────────────
PORT=3399

# ── Red ─────────────────────────────────────────────────────
# El PC secundario solo escucha en localhost (no expone MySQL).
POS_ALLOW_LAN=false
POS_BIND_HOST=127.0.0.1

# ── MariaDB embebida ─────────────────────────────────────────
# NO iniciar MariaDB local en el PC secundario.
# (Se conecta al del PC principal)
TECNO_CAJA_SKIP_LOCAL_MARIADB=true
TECNO_CAJA_MARIADB_BUNDLE_DIR=

# ── MySQL LAN ────────────────────────────────────────────────
# El secundario no expone MySQL.
TECNO_CAJA_MYSQL_ALLOW_LAN=false
TECNO_CAJA_MYSQL_BIND_HOST=127.0.0.1

# ── Credenciales LAN (copiadas del .env del PC principal) ───
TECNO_CAJA_LAN_DB_PASSWORD=<TECNO_CAJA_LAN_DB_PASSWORD_DEL_PC_PRINCIPAL>
TECNO_CAJA_LAN_DB_USER=tecnocaja_terminal

# ── Firebase (opcional) ──────────────────────────────────────
# Si el negocio usa sync con la nube, pega aquí la misma config
# del PC principal. Si no usas nube, puedes dejar en blanco.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=

# ── Otros ────────────────────────────────────────────────────
TECNO_CAJA_LICENSE_UID=<MISMO_QUE_PC_PRINCIPAL>
TECNO_CAJA_SECURITY_PASSWORD=<MISMO_QUE_PC_PRINCIPAL>
TECNO_CAJA_BUSINESS_ID=
