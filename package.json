{
  "name": "pos-system",
  "version": "1.1.11",
  "description": "Sistema POS moderno, rapido y profesional inspirado en Eleventa.",
  "main": "electron/main.js",
  "scripts": {
    "db:init": "node scripts/init-db.js",
    "db:init:mysql": "node scripts/init-db-mysql.js",
    "db:migrate:mysql": "node scripts/migrate-sqlite-to-mysql.js",
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "chcp 65001 > nul && set ELECTRON_RUN_AS_NODE=&& .\\node_modules\\electron\\dist\\electron.exe .",
    "desktop": "chcp 65001 > nul && set ELECTRON_RUN_AS_NODE=&& .\\node_modules\\electron\\dist\\electron.exe .",
    "build:desktop": "node scripts/prepare-mariadb-bundle.js && electron-builder --win nsis",
    "publish:desktop": "node scripts/prepare-mariadb-bundle.js && electron-builder --win nsis --publish always",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump patch",
    "release:minor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump minor",
    "release:major": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release.ps1 -Bump major",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [],
  "author": "Emilio",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@xmldom/xmldom": "^0.8.13",
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "dgii-rnc": "^1.0.1",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^10.3.0",
    "form-data": "^4.0.5",
    "formidable": "^3.5.1",
    "helmet": "^8.0.0",
    "jose": "^5.10.0",
    "jspdf": "^4.2.1",
    "lru-cache": "^10.4.3",
    "mysql2": "^3.22.0",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5",
    "xml-crypto": "^6.1.2",
    "xmlbuilder": "^11.0.1"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "playwright": "^1.58.2",
    "prettier": "^3.3.3",
    "puppeteer": "^24.41.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/**/README.md"
    ]
  },
  "build": {
    "appId": "com.emilio.possystem",
    "productName": "Tecno Caja",
    "copyright": "Copyright 2026 Emilio. Todos los derechos reservados.",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "elfavoritord",
        "repo": "tecnocaja-pos",
        "releaseType": "release"
      }
    ],
    "files": [
      "electron/**/*",
      "js/**/*",
      "css/**/*",
      "db/**/*",
      "scripts/**/*",
      "modules/**/*",
      "server/**/*",
      "config/**/*",
      "db.js",
      "db-local.js",
      "server.js",
      "package.json",
      "package-lock.json",
      "firebase-key.json",
      "index.html",
      ".env"
    ],
    "extraResources": [
      {
        "from": "build/mariadb-runtime",
        "to": "mariadb-runtime"
      },
      {
        "from": "build/vc_redist.x64.exe",
        "to": "vc_redist.x64.exe"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asar": false,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "TecnoCaja-Setup-${version}.exe",
      "fileAssociations": [],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tecno Caja",
      "license": "build/license.txt",
      "runAfterFinish": true,
      "menuCategory": "Tecno Caja"
    }
  }
}
